# Normalize EOL for all files that Git considers text files.
* text=auto eol=lf

# Godot-specific text files
*.gd text eol=lf
*.tscn text eol=lf
*.tres text eol=lf
*.import text eol=lf
*.project text eol=lf
*.cfg text eol=lf

# Exclude export files from diffs
*.pck binary
*.apk binary
*.aab binary
*.exe binary
*.dmg binary
*.ipa binary
*.zip binary
